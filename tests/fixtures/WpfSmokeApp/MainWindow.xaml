<Window x:Class="WpfSmokeApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WPF Smoke Test" Height="760" Width="760"
        AutomationProperties.AutomationId="mainWindow">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="WPF Smoke Test App" FontSize="18" FontWeight="Bold"
                   Margin="10" AutomationProperties.AutomationId="lblHeader"/>

        <!-- Settings Panel (for root_id scoping) -->
        <GroupBox Grid.Row="1" Header="Settings Panel" Margin="10"
                  AutomationProperties.AutomationId="settingsPanel">
            <StackPanel Margin="5">

                <!-- Invoke Button -->
                <Button Content="Invoke Me" Margin="0,5"
                        AutomationProperties.AutomationId="btnInvoke"
                        Click="BtnInvoke_Click"/>

                <!-- Toggle CheckBox -->
                <CheckBox Content="Enable Feature" Margin="0,5"
                          AutomationProperties.AutomationId="chkEnabled"
                          IsChecked="{Binding IsFeatureEnabled, Mode=TwoWay}"/>

                <!-- TextBox for read_text testing -->
                <TextBox x:Name="txtOutput"
                         Text="{Binding StatusText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,5" IsReadOnly="True"
                         AutomationProperties.AutomationId="txtOutput"/>

                <!-- ComboBox for selection testing -->
                <ComboBox Margin="0,5"
                          AutomationProperties.AutomationId="cmbOptions"
                          SelectedIndex="0">
                    <ComboBoxItem Content="Option A"/>
                    <ComboBoxItem Content="Option B"/>
                    <ComboBoxItem Content="Option C"/>
                </ComboBox>

                <!-- Duplicate-named button inside panel (for root_id test) -->
                <Button Content="Action (Inside)" Margin="0,5"
                        AutomationProperties.AutomationId="btnAction"/>

                <!-- Scoped button -->
                <Button Content="Scoped Button" Margin="0,5"
                        AutomationProperties.AutomationId="btnScoped"
                        Click="BtnScoped_Click"/>

                <!-- ListView for collection testing -->
                <ListView Margin="0,5" Height="80"
                          AutomationProperties.AutomationId="lstItems"
                          ItemsSource="{Binding Items}"/>

            </StackPanel>
        </GroupBox>

        <!-- DataGrid for select/read and runtime workflow testing -->
        <DataGrid x:Name="CueDataGrid"
                  Grid.Row="2" Margin="10,5" Height="145"
                  AutomationProperties.AutomationId="dataGrid"
                  AutoGenerateColumns="False"
                  SelectionMode="Extended"
                  SelectionUnit="FullRow"
                  SelectedIndex="0"
                  IsReadOnly="True"
                  AllowDrop="True"
                  SelectionChanged="DataGrid_SelectionChanged"
                  PreviewKeyDown="DataGrid_PreviewKeyDown"
                  PreviewMouseLeftButtonDown="CueDataGrid_PreviewMouseLeftButtonDown"
                  PreviewMouseMove="CueDataGrid_PreviewMouseMove"
                  DragOver="CueDataGrid_DragOver"
                  Drop="CueDataGrid_Drop"
                  ItemsSource="{Binding CueRows}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Start" Binding="{Binding Start}" Width="*"/>
                <DataGridTextColumn Header="End" Binding="{Binding End}" Width="*"/>
                <DataGridTextColumn Header="Character" Binding="{Binding Character}" Width="*"/>
                <DataGridTextColumn Header="Phrase" Binding="{Binding Phrase}" Width="2*"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Runtime workflow panel -->
        <Grid Grid.Row="3" Margin="10,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <GroupBox Grid.Column="0" Header="Characters">
                <ListBox x:Name="CharactersListBox"
                         Height="125"
                         AutomationProperties.AutomationId="CharactersListBox"
                         ItemsSource="{Binding Characters}"
                         SelectionChanged="CharactersListBox_SelectionChanged">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="AutomationProperties.Name" Value="{Binding Name}"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Name}" Width="80"/>
                                <CheckBox AutomationProperties.AutomationId="CharGender"
                                          Content="{Binding GenderLabel}"
                                          IsChecked="{Binding IsFemale, Mode=TwoWay}"
                                          Checked="CharGender_Checked"
                                          Unchecked="CharGender_Checked"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </GroupBox>

            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                <TextBlock Text="{Binding GenderStatusText}"
                           AutomationProperties.AutomationId="genderStatus"
                           Margin="0,0,0,8"/>
                <Button Content="Undo" Margin="0,0,0,8"
                        AutomationProperties.AutomationId="menuItemUndo"
                        Click="Undo_Click"/>

                <!-- Duplicate-named button outside panel -->
                <Button Content="Action (Outside)" Margin="0,0,0,8"
                        AutomationProperties.AutomationId="btnAction"/>

                <Button Content="Outer Button" Margin="0,0,0,8"
                        AutomationProperties.AutomationId="btnOuter"/>

                <Button Content="Open File..." Margin="0"
                        AutomationProperties.AutomationId="btnOpenFile"
                        Click="BtnOpenFile_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
