{
  "schema": "netcoredbg.runtime_smoke.diagnostics.v1",
  "id": "wpf-grid-oracle-pack",
  "status": "PASS",
  "description": "Schema-first oracle pack for WPF DataGrid smoke checks.",
  "checks": [
    {
      "id": "visible-row-count",
      "probe": "ui.grid",
      "expect": {
        "min_rows": 1,
        "identity": {
          "column": "Phrase"
        }
      },
      "on_blocked": {
        "next_step": "Replay with a UI backend that exposes GridPattern or bounded descendant text evidence."
      }
    }
  ],
  "limits": {
    "max_text_length": 240,
    "max_list_items": 8,
    "max_json_bytes": 32768
  },
  "redaction": {
    "omit_fields": [
      "raw_tree",
      "window_tree",
      "ui_tree",
      "screenshot_base64",
      "access_token",
      "api_key",
      "password",
      "secret"
    ]
  }
}
