{
  "schema": "netcoredbg.runtime_smoke.diagnostics.v1",
  "app": {
    "name": "WpfSmokeApp",
    "process_name": "dotnet",
    "expected_modules": [
      "WpfSmokeApp.dll"
    ]
  },
  "status": "PASS",
  "observations": [],
  "wait_json": {
    "path": ".agent/runtime-smoke/app-diagnostics.json",
    "condition": {
      "jsonpath": "$.status",
      "expected": "PASS"
    },
    "timeout_ms": 5000,
    "poll_interval_ms": 100
  },
  "redaction": {
    "omit_fields": [
      "raw_tree",
      "window_tree",
      "ui_tree",
      "screenshot_base64",
      "access_token",
      "api_key",
      "password",
      "secret"
    ]
  },
  "limits": {
    "max_text_length": 240,
    "max_list_items": 8,
    "max_json_bytes": 32768
  }
}
