{
  "schema": "netcoredbg.runtime_smoke.v2",
  "name": "NovaScript v0.19.0 action-oracle app diagnostics consumer check",
  "description": "Copy this plan into a NovaScript checkout, replace the placeholder launch paths and UI selector, then run it with netcoredbg-mcp 0.19.0 to verify generated action-oracle app_diagnostics evidence.",
  "diagnostics": {
    "app_diagnostics": {
      "diagnostic_launch": {
        "kind": "app_diagnostics",
        "schema": "netcoredbg.runtime_smoke.diagnostics.v1",
        "evidence": {
          "directory": ".agent/runtime-smoke/app-diagnostics",
          "path": ".agent/runtime-smoke/app-diagnostics/novascript-action-oracle.json"
        },
        "redacted_env_values": true
      }
    }
  },
  "baseline": {
    "steps": [
      {
        "id": "launch_novascript_with_app_diagnostics",
        "kind": "isolated_profile.launch",
        "launch": {
          "program": "<NOVASCRIPT_PROGRAM_DLL_OR_EXE>",
          "cwd": "<NOVASCRIPT_DEBUG_OUTPUT_DIR>",
          "pre_build": true,
          "build_project": "<NOVASCRIPT_PROJECT_FILE>",
          "build_configuration": "Debug",
          "env": {
            "NOVASCRIPT_UI_TEST_MODE": "1",
            "NOVASCRIPT_UI_TEST_AUTO_OPEN_DOCUMENT": "1",
            "NOVASCRIPT_UI_TEST_DISABLE_RESTORE": "1",
            "WINDIR": "C:\\WINDOWS",
            "windir": "C:\\WINDOWS",
            "SystemRoot": "C:\\WINDOWS"
          }
        }
      }
    ]
  },
  "generate": {
    "template": "novascript-action-oracle",
    "id_pattern": "{id}",
    "matrix": [
      {
        "id": "action_oracle_diagnostics",
        "route": "action-oracle-diagnostics",
        "action": {
          "kind": "ui.invoke",
          "selector": {
            "automation_id": "<ACTION_ORACLE_TRIGGER_AUTOMATION_ID>",
            "control_type": "Button"
          }
        },
        "settle": {
          "idle_ms": 500
        },
        "oracles": [
          {
            "kind": "app_diagnostics",
            "name": "novascript_action_oracle",
            "schema": "netcoredbg.runtime_smoke.diagnostics.v1",
            "app": {
              "name": "NovaScript",
              "process_name": "NovaScript",
              "expected_modules": [
                "NovaScript.dll"
              ],
              "require_active_process": true
            },
            "status": "PASS",
            "observations": [],
            "workspace": {
              "path": "<NOVASCRIPT_REPO>"
            },
            "artifacts": {
              "expected": [
                ".agent/runtime-smoke/app-diagnostics/novascript-action-oracle.json"
              ]
            },
            "redaction": {
              "omit_fields": [
                "raw_tree",
                "window_tree",
                "ui_tree",
                "screenshot_base64",
                "access_token",
                "api_key",
                "password",
                "secret"
              ]
            },
            "limits": {
              "max_text_length": 240,
              "max_list_items": 8,
              "max_json_bytes": 32768
            }
          }
        ]
      }
    ]
  },
  "cleanup": {
    "steps": [
      {
        "kind": "debug.stop"
      },
      {
        "kind": "process.registry.assert_empty"
      }
    ]
  }
}
